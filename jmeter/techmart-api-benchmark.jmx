              <stringProp name="-675513540">"success":true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">ASSERTION_TEXT</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">16</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>

      <!-- ================================================================ -->
      <!-- THREAD GROUP 4 — Monitoring (Light Reads)                       -->
      <!-- ================================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="[TG-04] Monitoring" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <stringProp name="LoopController.loops">-1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(monitor.threads,2)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${__P(monitor.rampup,2)}</stringProp>
        <longProp name="ThreadGroup.duration">${__P(monitor.duration,120)}</longProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <longProp name="ThreadGroup.delay">0</longProp>
      </ThreadGroup>
      <hashTree>

        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Think Time (1-3s)" enabled="true">
          <stringProp name="delay">1000</stringProp>
          <stringProp name="range">2000</stringProp>
        </UniformRandomTimer>
        <hashTree/>

        <!-- ── GET health ── -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /api/monitor/health" enabled="true">
          <stringProp name="HTTPSampler.path">${basePath}/monitor/health</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
