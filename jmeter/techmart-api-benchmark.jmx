      <hashTree/>

      <ResultCollector guiclass="SimpleDataWriter" testclass="ResultCollector" testname="Raw Results (JTL)" enabled="true">
        <boolProp name="ResultCollector.success_logging">true</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
            <latitude>false</latitude>
            <longitude>false</longitude>
