        </hashTree>

        <!-- ── GET price range ── -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /api/products/price-range" enabled="true">
          <stringProp name="HTTPSampler.path">${basePath}/products/price-range?min=10&amp;max=2000</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert: 200 + success" enabled="true">
            <collectionProp name="Assertion.test_strings">
              <stringProp name="-675513540">"success":true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">ASSERTION_TEXT</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">16</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- ── GET product count ── -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /api/products/count" enabled="true">
          <stringProp name="HTTPSampler.path">${basePath}/products/count</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert: 200 + success" enabled="true">
            <collectionProp name="Assertion.test_strings">
              <stringProp name="-675513540">"success":true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">ASSERTION_TEXT</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">16</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- ── POST create product ── -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /api/products" enabled="true">
          <stringProp name="HTTPSampler.path">${basePath}/products</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.value">{&quot;name&quot;:&quot;Perf-Test Laptop ${__threadNum}&quot;,&quot;sku&quot;:&quot;PERF-${__time(yyyyMMddHHmmss)}-${__threadNum}&quot;,&quot;description&quot;:&quot;Performance test product&quot;,&quot;price&quot;:&quot;799.99&quot;,&quot;categoryId&quot;:&quot;1&quot;,&quot;brand&quot;:&quot;PerfTest&quot;}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert: 201 Created" enabled="true">
            <collectionProp name="Assertion.test_strings">
              <stringProp name="-675513540">"success":true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">ASSERTION_TEXT</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">16</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>

      <!-- ================================================================ -->
      <!-- THREAD GROUP 2 — User Operations (Mixed)                        -->
      <!-- ================================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="[TG-02] User Operations" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <stringProp name="LoopController.loops">-1</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${__P(user.threads,10)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${__P(user.rampup,5)}</stringProp>
        <longProp name="ThreadGroup.duration">${__P(user.duration,120)}</longProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <longProp name="ThreadGroup.delay">0</longProp>
      </ThreadGroup>
      <hashTree>

        <CSVDataSet guiclass="TestBeanGUI" testclass="CSVDataSet" testname="CSV Data — Users" enabled="true">
          <stringProp name="delimiter">,</stringProp>
          <stringProp name="fileEncoding">UTF-8</stringProp>
          <stringProp name="filename">data/users.csv</stringProp>
          <boolProp name="ignoreFirstLine">true</boolProp>
          <boolProp name="quotedData">false</boolProp>
          <boolProp name="recycle">true</boolProp>
          <stringProp name="shareMode">all</stringProp>
          <boolProp name="stopThread">false</boolProp>
          <stringProp name="variableNames">csvUsername,csvEmail,csvPassword</stringProp>
        </CSVDataSet>
        <hashTree/>

        <UniformRandomTimer guiclass="UniformRandomTimerGui" testclass="UniformRandomTimer" testname="Think Time (200-800ms)" enabled="true">
          <stringProp name="delay">200</stringProp>
          <stringProp name="range">600</stringProp>
        </UniformRandomTimer>
        <hashTree/>

        <!-- ── GET all users ── -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /api/users" enabled="true">
          <stringProp name="HTTPSampler.path">${basePath}/users</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert: success" enabled="true">
            <collectionProp name="Assertion.test_strings">
              <stringProp name="-675513540">"success":true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">ASSERTION_TEXT</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">16</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- ── POST register user ── -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /api/users/register" enabled="true">
          <stringProp name="HTTPSampler.path">${basePath}/users/register</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">
              <elementProp name="" elementType="HTTPArgument">
                <stringProp name="HTTPArgument.value">{&quot;username&quot;:&quot;perf_${__time(yyyyMMddHHmmss)}_${__threadNum}&quot;,&quot;email&quot;:&quot;perf_${__time(yyyyMMddHHmmss)}_${__threadNum}@test.com&quot;,&quot;password&quot;:&quot;PerfPass123!&quot;,&quot;firstName&quot;:&quot;Perf&quot;,&quot;lastName&quot;:&quot;User${__threadNum}&quot;}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert: 201 + success" enabled="true">
